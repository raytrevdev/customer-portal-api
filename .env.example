# ---- Server ----
NODE_ENV=development
PORT=3000

# ---- Database ----
# When running with Docker Compose, DB_HOST must be "db" (the compose service name).
# When running the app natively on your machine, use "localhost".
DB_HOST=db
DB_PORT=5432
DB_NAME=customer_portal
DB_USER=postgres
DB_PASSWORD=postgres

# ---- Auth ----
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=1d

# ---- Seeded admin account (created by the seeder) ----
ADMIN_EMAIL=admin@portal.com
ADMIN_PASSWORD=Admin@123

# ---- Rate limiting (optional; sensible defaults applied if unset) ----
# Strict limit on auth endpoints, lenient limit on the rest of the API.
AUTH_RATE_MAX=20
AUTH_RATE_WINDOW_MS=900000
API_RATE_MAX=300
API_RATE_WINDOW_MS=900000
